model UserRoles {
  id            String       @id @default(uuid(7))
  userCompanyId        String
  roleId        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  deletedAt     DateTime?

  user        UserCompanies            @relation(fields: [userCompanyId], references: [id])
  role        Roles           @relation(fields: [roleId], references: [id])
  wages       UserRoleWage[]

  @@unique([userCompanyId, roleId])
}

model UserRoleWage {
  id          String    @id @default(uuid(7))
  userRoleId  String
  wages       Float     @default(0.0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  deletedAt   DateTime?

  userRole UserRoles @relation(fields: [userRoleId], references: [id])
}
