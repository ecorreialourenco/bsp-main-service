model Office {
  id        String       @id @default(uuid(7))
  name      String
  address   String
  city      String
  state     String
  country   String
  zipCode   String
  companyId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  company Company @relation(fields: [companyId], references: [id])

  productStock ProductStock[]
}
