model CompanyClientRole {
    id        String    @id @default(uuid(7))
    companyId String
    name      String
    createdAt DateTime  @default(now())
    updatedAt DateTime  @default(now()) @updatedAt
    deletedAt DateTime?

    company Company @relation(fields: [companyId], references: [id])

    clients  Client[]
    discount CompanyClientDiscount[]
}

model CompanyClientDiscount {
    id                  String      @id @default(uuid(7))
    companyClientRoleId String      
    percentage          Float       @default(0.00)
    categoryId          String
    productTypeId       String
    createdAt           DateTime    @default(now())
    updatedAt           DateTime    @default(now()) @updatedAt
    deletedAt           DateTime?

    role        CompanyClientRole @relation(fields: [companyClientRoleId], references: [id])
    cagetogy    Category          @relation(fields: [categoryId], references: [id])
    productType ProductType       @relation(fields: [productTypeId], references: [id])
}
